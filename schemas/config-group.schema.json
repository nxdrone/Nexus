{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus/schemas/config-group.schema.json",
  "title": "Config Group",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "display_name": { "type": "string" },
    "purpose": { "type": "string" },
    "mutability": { "type": "string" },
    "requirement": {
      "type": "string",
      "enum": ["required", "optional"]
    },
    "example_fields": { "type": "object" },
    "client_notes": { "type": "string" }
  },
  "required": [
    "id",
    "display_name",
    "purpose",
    "mutability",
    "requirement",
    "example_fields",
    "client_notes"
  ]
}
