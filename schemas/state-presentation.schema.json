{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus/contracts/schemas/state-presentation.schema.json",
  "title": "State Presentation",
  "description": "Schema for canonical client-visible state color and pattern semantics.",
  "type": "object",
  "required": [
    "state_id",
    "display_name",
    "meaning",
    "priority",
    "safety_level",
    "color_name",
    "color_token",
    "default_hex",
    "pattern_intent",
    "accessibility",
    "notes"
  ],
  "properties": {
    "state_id": {
      "type": "string",
      "pattern": "^[a-z0-9_+]+$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "meaning": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "integer",
      "minimum": 0
    },
    "safety_level": {
      "type": "string",
      "enum": [
        "safe",
        "caution",
        "hazard",
        "fault",
        "unknown"
      ]
    },
    "color_name": {
      "type": "string",
      "minLength": 1
    },
    "color_token": {
      "type": "string",
      "pattern": "^state\\.[a-z0-9_]+$"
    },
    "default_hex": {
      "type": "string",
      "pattern": "^#[A-Fa-f0-9]{6}$"
    },
    "pattern_intent": {
      "type": "string",
      "enum": [
        "solid",
        "blink",
        "twinkle",
        "alternate"
      ]
    },
    "accessibility": {
      "type": "object",
      "required": [
        "requires_shape_or_icon",
        "requires_contrast_aid",
        "notes"
      ],
      "properties": {
        "requires_shape_or_icon": {
          "type": "boolean"
        },
        "requires_contrast_aid": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
