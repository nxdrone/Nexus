{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus/schemas/capability.schema.json",
  "title": "Capability",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "display_name": { "type": "string" },
    "category": { "type": "string" },
    "stability_class": {
      "type": "string",
      "enum": ["required", "optional", "extension", "experimental"]
    },
    "supported": { "type": "boolean" },
    "description": { "type": "string" }
  },
  "required": [
    "id",
    "display_name",
    "category",
    "stability_class",
    "supported",
    "description"
  ]
}
